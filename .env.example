# ── E-MAIL (Gmail) ────────────────────────────────────────────────
# Conta Gmail que vai enviar as notificações
GMAIL_USER=seuemail@gmail.com
# Senha de App do Google (não é a senha normal — veja o passo a passo)
GMAIL_PASS=xxxx xxxx xxxx xxxx

# ── WHATSAPP (Z-API) ──────────────────────────────────────────────
# Encontre esses valores no painel em z-api.io → sua instância
ZAPI_INSTANCE_ID=SUA_INSTANCE_ID
ZAPI_TOKEN=SEU_TOKEN
ZAPI_CLIENT_TOKEN=SEU_CLIENT_TOKEN
